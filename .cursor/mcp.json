{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ]
    },
    "playwright": {
      "command": "pnpm dlx",
      "args": ["@playwright/mcp@latest"]
    },
    "chrome-devtools": {
      "command": "pnpm dlx",
      "args": ["chrome-devtools-mcp@latest"]
    }
  }
}
