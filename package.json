{
  "name": "kansu-infinite-scroll-archiver",
  "description": "Webページの無限スクロールや自動で表示が更新される欄から好きな項目を抽出し、ブラウザで保存・検索できます。好きなページで好きな保存対象を設定できます。データは実行デバイスにのみ保存し、設定と内容のインポート・エクスポートにも対応しています。",
  "private": true,
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": "^24.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okathira-dev/kansu-infinite-scroll-archiver.git"
  },
  "bugs": {
    "url": "https://github.com/okathira-dev/kansu-infinite-scroll-archiver/issues"
  },
  "homepage": "https://github.com/okathira-dev/kansu-infinite-scroll-archiver#readme",
  "scripts": {
    "dev": "cross-env KANSU_DEV_OPEN_FIXTURE=1 concurrently -k -n fixture,ext \"pnpm debug:fixture\" \"pnpm dev:extension\"",
    "dev:firefox": "cross-env KANSU_DEV_OPEN_FIXTURE=1 concurrently -k -n fixture,ext \"pnpm debug:fixture\" \"pnpm dev:extension:firefox\"",
    "dev:extension": "wxt",
    "dev:extension:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "prepare": "husky",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "lint-md": "markdownlint-cli2 **/*.{md,mdx,mdc}",
    "lint-md:fix": "markdownlint-cli2 **/*.{md,mdx,mdc} --fix",
    "biome-check": "biome check",
    "biome-check:fix": "biome check --write",
    "check": "pnpm biome-check && pnpm compile && pnpm lint-md",
    "check:fix": "pnpm biome-check:fix && pnpm lint-md:fix",
    "test": "vitest run",
    "test:storybook": "vitest run --project=storybook",
    "test:watch": "vitest",
    "e2e": "pnpm build && playwright test",
    "e2e:watch": "pnpm build && playwright test --ui",
    "e2e:only": "playwright test",
    "debug:fixture": "node scripts/serve-e2e-fixture.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "wanakana": "^5.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.2",
    "@wxt-dev/module-react": "^1.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2",
    "wxt": "^0.20.20"
  }
}
